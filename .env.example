# Evolution API (WhatsApp) — server-only
# Necessárias para conectar o WhatsApp da clínica em /[domain]/settings.
# Sem EVOLUTION_API_URL e EVOLUTION_API_KEY a rota
# /api/whatsapp/instance/connect responde 503 com
# "Evolution API nao configurada no servidor.".

# URL pública HTTPS do servidor Evolution (sem barra final).
# Ex.: https://evo.suaempresa.com
EVOLUTION_API_URL=

# API key global da Evolution (header `apikey`).
# Deve coincidir com a chave configurada no servidor Evolution.
EVOLUTION_API_KEY=

# URL pública HTTPS do CRM, usada para registrar o webhook
# /api/whatsapp/webhook/{instance} quando a instance é criada/conectada.
#
#   PROD (Vercel): https://seu-app.vercel.app
#   DEV  (local):  https://<algo>.trycloudflare.com  (Quick Tunnel)
#                  ou https://<seu-host>.<seu-dominio>.com (Named Tunnel)
#                  Suba o tunnel com `npm run tunnel` (Quick) ou
#                  `npm run tunnel:named` (Named, URL fixa).
#                  Sem o tunnel rodando, mensagens recebidas só chegam pelo
#                  polling de fallback de 30s do `pullEvolutionForActive`.
EVOLUTION_WEBHOOK_BASE_URL=

# Nome do Named Tunnel do Cloudflare (apenas dev, opcional).
# Só usado pelo script `npm run tunnel:named`. Deixe em branco se for usar
# Quick Tunnel (`npm run tunnel`).
CLOUDFLARED_TUNNEL_NAME=

# ── Supabase (também já lidas pelo app) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app, usada em links gerados em e-mails/agenda.
NEXT_PUBLIC_PUBLIC_APP_URL=
